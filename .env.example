# Discord bot token (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Application/client ID (Developer Portal -> General Information)
CLIENT_ID=

# Guild (server) ID for instant slash-command registration during development.
# Leave blank to register commands globally (can take up to ~1 hour to appear).
GUILD_ID=

# Port for the keep-alive web server. Render sets this automatically.
PORT=3000

# Seconds of audio history to retain per speaker. Each second ~= 192 KB RAM per
# speaker, so this scales the per-user buffer linearly. Default 15.
BUFFER_SECONDS=15

# Max simultaneous speakers to buffer (~2.9 MB RAM each at 15s). Guards the 512 MB cap.
MAX_USERS=12

# How many clips to encode concurrently (each spawns an FFmpeg process).
ENCODE_CONCURRENCY=1
